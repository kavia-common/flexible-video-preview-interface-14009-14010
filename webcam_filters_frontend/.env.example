# Frontend runtime configuration (Create React App)
# Set these in the real .env (managed by orchestrator/deployment).

# Base URL for backend HTTP API (preferred)
REACT_APP_API_BASE=http://localhost:4000

# Alternative backend URL (used if API_BASE missing)
REACT_APP_BACKEND_URL=http://localhost:4000

# WebSocket base URL (optional; if absent it is derived from API_BASE/BACKEND_URL)
REACT_APP_WS_URL=ws://localhost:4000

# Frontend URL (optional; defaults to window.location.origin)
REACT_APP_FRONTEND_URL=http://localhost:3000

# Logging verbosity (optional)
REACT_APP_LOG_LEVEL=info

# Optional JSON blobs
REACT_APP_FEATURE_FLAGS={}
REACT_APP_EXPERIMENTS_ENABLED=false
